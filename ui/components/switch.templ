package components

type SwitchProps struct {
	Label string
}

templ Switch(props SwitchProps) {
	<div class="form-control">
		<label class="label cursor-pointer gap-[2rem]">
			<span class="label-text">{ props.Label }</span>
			<input type="checkbox" class="toggle"/>
		</label>
	</div>
}
